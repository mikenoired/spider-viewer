{
	"name": "spider-viewer",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev --port 3000",
		"build": "vite build",
		"start": "node ./scripts/serve.mjs",
		"start:prod": "NODE_ENV=production node ./scripts/serve.mjs",
		"start:railway": "NODE_ENV=production HOST=0.0.0.0 node ./scripts/serve.mjs",
		"preview": "vite preview",
		"test": "vitest run",
		"db:generate": "bunx --bun drizzle-kit generate",
		"db:migrate": "bunx --bun drizzle-kit migrate",
		"db:push": "bunx --bun drizzle-kit push",
		"db:deploy": "drizzle-kit push",
		"db:studio": "bunx --bun drizzle-kit studio",
		"db:seed:test-users": "bun run ./scripts/seed-requested-users.ts",
		"lint": "oxlint .",
		"lint:fix": "oxlint . --fix",
		"format": "oxfmt .",
		"format:check": "oxfmt --check .",
		"lint:format": "bun run format",
		"lint:check": "bun run lint && bun run format:check"
	},
	"dependencies": {
		"@tailwindcss/vite": "^4.2.2",
		"@tanstack/react-devtools": "^0.10.0",
		"@tanstack/react-form": "^1.28.5",
		"@tanstack/react-router": "^1.168.4",
		"@tanstack/react-router-devtools": "^1.166.11",
		"@tanstack/react-router-ssr-query": "^1.166.10",
		"@tanstack/react-start": "^1.167.8",
		"@tanstack/react-table": "^8.21.3",
		"@tanstack/router-plugin": "^1.167.5",
		"@tesseract.js-data/eng": "^1.0.0",
		"@tesseract.js-data/rus": "^1.0.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"date-fns": "^4.1.0",
		"docx": "^9.6.1",
		"drizzle-orm": "^0.45.1",
		"jose": "^6.2.2",
		"lucide-react": "^1.7.0",
		"motion": "^12.38.0",
		"next-themes": "^0.4.6",
		"pino": "^10.3.1",
		"postgres": "^3.4.8",
		"react": "^19.2.0",
		"react-day-picker": "^9.14.0",
		"react-dom": "^19.2.0",
		"redis": "^5.11.0",
		"shadcn": "^4.1.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.2.2",
		"tesseract.js": "^7.0.0",
		"tw-animate-css": "^1.4.0",
		"vaul": "^1.1.2",
		"xlsx": "^0.18.5",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@tailwindcss/typography": "^0.5.16",
		"@tanstack/devtools-vite": "^0.6.0",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.0",
		"@types/node": "^25.5.0",
		"@types/react": "^19.2.0",
		"@types/react-dom": "^19.2.0",
		"@vitejs/plugin-react": "^6.0.1",
		"drizzle-kit": "^0.31.10",
		"jsdom": "^29.0.1",
		"oxfmt": "0.42.0",
		"oxlint": "1.57.0",
		"radix-ui": "^1.4.3",
		"typescript": "^6.0.2",
		"vite": "^8.0.3",
		"vite-tsconfig-paths": "^6.1.1",
		"vitest": "^4.1.1"
	},
	"packageManager": "bun@1.3.11"
}
