POSTGRES_DB=spider_viewer
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/spider_viewer
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=replace-this-with-a-long-random-string
AUTH_SUPERUSERS_JSON=[{"login":"supervisor-1","password":"ChangeMe123!"},{"login":"supervisor-2","password":"ChangeMe456!"},{"login":"supervisor-3","password":"ChangeMe789!"}]
HOST=127.0.0.1
SHUTDOWN_TIMEOUT_MS=30000
HEALTHCHECK_REDIS_REQUIRED=false
AUTH_COOKIE_SECURE=false
DB_BACKUP_DIR=/opt/spider-viewer/backups/postgres
DB_BACKUP_RETENTION_DAYS=7
